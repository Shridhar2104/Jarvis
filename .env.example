# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...          # required — GPT-4o
ANTHROPIC_API_KEY=             # optional — Claude fallback

# ── Core ─────────────────────────────────────────────────────────────────────
JARVIS_WAKE_WORD=jarvis        # wake word string (case-insensitive)
JARVIS_MODEL=gpt-4o            # LLM model name
JARVIS_VOICE=samantha          # macOS TTS voice name

# ── STT ──────────────────────────────────────────────────────────────────────
JARVIS_STT=google              # google | whisper

# ── Terminal ─────────────────────────────────────────────────────────────────
# RESTRICTED | STANDARD | ELEVATED | UNRESTRICTED
JARVIS_TERMINAL_LEVEL=STANDARD

# ── Agent Orchestrator ────────────────────────────────────────────────────────
JARVIS_AGENT_TIMEOUT=1800      # max seconds per agent before timeout (default 30m)

# ── Life OS / Nudge ───────────────────────────────────────────────────────────
JARVIS_NUDGE_ENABLED=true      # set to false to silence all nudges globally

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use default: ~/Library/Application Support/Jarvis/brain.db
JARVIS_DB_PATH=
